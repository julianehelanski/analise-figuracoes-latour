# Modelo de configuração local. Copie para .env e ajuste os caminhos.
# O .env não é versionado (ver .gitignore).

# Caminho local onde ficam as exportações brutas das bases bibliográficas,
# caso prefira mantê-las fora do repositório (por exemplo, em pasta do Drive
# sincronizada). Se vazio, os scripts usam corpus/exports/ no próprio repo.
CORPUS_EXPORTS_PATH=

# Caminho local onde fica o texto integral dos artigos (PDFs ou txt extraído).
# Copyright: nunca entra no repositório.
CORPUS_FULLTEXT_PATH=
